# ADM FlexNet Server - Environment Configuration
# Copy to .env and adjust values as needed

ADM_FLEXNET_HOSTNAME=name_of_server
ADM_FLEXNET_MAC_ADDRESS=XX:XX:XX:XX:XX:XX
ADM_FLEXNET_NLM_URL=https://damassets.autodesk.net/content/dam/autodesk/www/files/linux/nlm11.19.9.0_ipv4_ipv6_linux64.tar.gz
ADM_FLEXNET_IMAGE=adlmflexnetserver:local
ADM_FLEXNET_PLATFORM=linux/amd64
ADM_FLEXNET_COMMAND=-z -datestamp

# (lmgrd) usage: lmgrd [-l [+]debug_log_path] [-2 -p] [-z] [-c license_file_list]
# (lmgrd)              [-datestamp]
# (lmgrd)              [-v] [-local]
# (lmgrd)              [-localonly]
# (lmgrd)              [-x lmdown|lmremove] [-help]
# (lmgrd)              [-servTransferred]
# (lmgrd) Use -l option before other options to log all debugging information to debug_log_path.
