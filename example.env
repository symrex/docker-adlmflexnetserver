# ============================================
# ADM FlexNet Server Configuration
# Copy this file to .env and update values
# ============================================

# Docker Image name (optional, defaults to newadmflexnet)
ADM_FLEXNET_IMAGE=newadmflexnet

# Server hostname (REQUIRED - must match registered hostname in Autodesk)
ADM_FLEXNET_HOSTNAME=name_of_server

# MAC address (REQUIRED - must match registered MAC address in Autodesk)
ADM_FLEXNET_MAC_ADDRESS=XX:XX:XX:XX:XX:XX

# Path to license file (optional, defaults to ./license.lic)
ADM_FLEXNET_LICENSE_PATH=./license.lic

# NLM Download URL (optional, defaults to latest Autodesk NLM)
ADM_FLEXNET_NLM_URL=https://damassets.autodesk.net/content/dam/autodesk/www/files/linux/nlm11-19-4-1-ipv4-ipv6-linux64.tar.gz
